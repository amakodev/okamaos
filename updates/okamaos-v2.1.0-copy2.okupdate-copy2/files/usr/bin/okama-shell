                         pygame.Rect(bx + 18, inp_y, inp_w, 36), 1, border_radius=6)
        pin_s = self.font_mdb.render(masked, True, COL_TEXT)
        self.screen.blit(pin_s, (bx + 28, inp_y + 8))
        hint_s = self.font_hint.render("[Enter] Confirm   [Esc/B] Cancel", True, COL_DIM)
        self.screen.blit(hint_s, (bx + 18, by + bh - 30))

