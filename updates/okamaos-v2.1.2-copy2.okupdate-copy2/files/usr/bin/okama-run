#!/usr/bin/env python3
"""okama-run — strict game launcher for OkamaOS.

Only one game may run at a time. Enforces the lock file, validates the
manifest, stops non-essential services, launches the game fullscreen,
waits for exit, recovers from crashes, and returns to okama-shell.

Usage:
  okama-run <game_id>
  okama-run <game_id> --no-suspend
"""

import sys
import os

_lib = os.environ.get("OKAMA_LIB", "")
if not _lib:
    _lib = os.path.join(os.path.dirname(os.path.realpath(__file__)), "../lib")
OKAMA_LIB_PATH = os.path.abspath(_lib)
sys.path.insert(0, OKAMA_LIB_PATH)

import argparse
import json
import subprocess
import signal
import time
import traceback
import shutil
import threading
import queue

import okamaos.config as cfg_mod
import okamaos.games as games_mod
import okamaos.manifest as manifest_mod
from okamaos.input_protocol import InputClient

def _fallback_base(kind: str) -> str:
    if kind == "run":
        base = os.environ.get("XDG_RUNTIME_DIR") or "/tmp"
    else:
        base = os.environ.get("XDG_STATE_HOME")
        if not base and os.environ.get("HOME"):
            base = os.path.join(os.environ["HOME"], ".local", "state")
        if not base:
            base = "/tmp"
    return os.path.join(base, "okamaos")


def _writable_dir(path: str) -> bool:
    try:
        os.makedirs(path, exist_ok=True)
    except OSError:
        return False
    return os.access(path, os.W_OK)


def _runtime_file(env_name: str, default: str, fallback_name: str) -> str:
    override = os.environ.get(env_name)
    if override:
        return override
    parent = os.path.dirname(default)
    if _writable_dir(parent):
        return default
    fallback_dir = os.path.join(_fallback_base("run"), "run")
    os.makedirs(fallback_dir, exist_ok=True)
    return os.path.join(fallback_dir, fallback_name)


def _runtime_dir(env_name: str, default: str, fallback_name: str) -> str:
    override = os.environ.get(env_name)
    if override:
        os.makedirs(override, exist_ok=True)
        return override
    if _writable_dir(default):
        return default
    fallback_dir = os.path.join(_fallback_base("state"), fallback_name)
    os.makedirs(fallback_dir, exist_ok=True)
    return fallback_dir


LOCK_FILE = _runtime_file("OKAMA_LOCK_FILE", "/var/run/okama-game.lock", "okama-game.lock")
HEARTBEAT_FILE = _runtime_file("OKAMA_GAME_HEARTBEAT", "/var/run/okama-game-heartbeat", "okama-game-heartbeat")
LOG_DIR = _runtime_dir("OKAMA_LOG_DIR", "/var/okamaos/logs", "logs")
SAVES_DIR = _runtime_dir("OKAMA_SAVES", "/var/okamaos/saves", "saves")
STATUS_FILE = os.environ.get("OKAMA_GAME_STATUS_FILE", os.path.join(LOG_DIR, "last-game-status.json"))

BOOTSTRAP_STUB = (
    "import runpy, sys; "
    "import okamaos.game_bootstrap; "
    "entry = sys.argv[1]; "
    "sys.argv = [entry] + sys.argv[2:]; "
    "runpy.run_path(entry, run_name='__main__')"
)

SUSPEND_SERVICES = [
    "S40okama-network",
]

_ACTIVE_PROC = None
_SERVICES_SUSPENDED = False


def _path_list(value: str) -> list:
    paths = []
    for part in value.split(os.pathsep):
        if not part:
            continue
        paths.append(part if os.path.isabs(part) else os.path.abspath(part))
    return paths


def _dedupe_paths(paths: list) -> list:
    result = []
    seen = set()
    for path in paths:
        if path and path not in seen:
            seen.add(path)
            result.append(path)
    return result


def _python_executable() -> str:
    for candidate in (sys.executable, shutil.which("python3"), shutil.which("python"), "/usr/bin/python3"):
        if candidate and os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return os.path.abspath(candidate)
    return sys.executable or "python3"


def _pygame_lib_dirs() -> list:
    version = f"python{sys.version_info.major}.{sys.version_info.minor}"
    candidates = [
        os.environ.get("OKAMA_PYGAME_LIBS", ""),
        os.path.join(sys.prefix, "lib", version, "site-packages", "pygame.libs"),
        os.path.join("/usr/lib", version, "site-packages", "pygame.libs"),
    ]
    return [path for path in candidates if path and os.path.isdir(path)]


def _conf_value(conf, key: str, default: str) -> str:
    return os.environ.get(f"OKAMA_{key}") or os.environ.get(key) or conf.get(key, default)


def _conf_float(conf, key: str, default: float) -> float:
    try:
        return float(_conf_value(conf, key, str(default)))
    except (TypeError, ValueError):
        return default


def _launcher_signal(signum, _frame):
    global _ACTIVE_PROC
    if _ACTIVE_PROC is not None and _ACTIVE_PROC.poll() is None:
        _terminate_process(_ACTIVE_PROC, f"launcher signal {signum}", 1.0)
    if _SERVICES_SUSPENDED:
        resume_services()
    release_lock()
    sys.exit(128 + int(signum))


def _pid_running(pid) -> bool:
    try:
        pid = int(pid)
    except (TypeError, ValueError):
        return False
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False


def acquire_lock(game_id: str) -> None:
    if os.path.exists(LOCK_FILE):
        current = ""
        pid = None
        try:
            with open(LOCK_FILE) as f:
                raw = f.read().strip()
            data = json.loads(raw)
            current = data.get("game_id", raw)
            pid = data.get("pid")
        except Exception:
            current = raw if "raw" in locals() else "unknown"
        if _pid_running(pid):
            print(f"ERROR: Game already running: {current}", file=sys.stderr)
            sys.exit(1)
        try:
            os.remove(LOCK_FILE)
        except OSError:
            print(f"ERROR: stale game lock could not be removed: {LOCK_FILE}", file=sys.stderr)
            sys.exit(1)
    with open(LOCK_FILE, "w") as f:
        json.dump({"game_id": game_id, "pid": None, "started_at": time.time()}, f)


def update_lock_pid(game_id: str, pid: int) -> None:
    try:
        with open(LOCK_FILE, "w") as f:
            json.dump({"game_id": game_id, "pid": pid, "started_at": time.time()}, f)
    except OSError:
        pass


def release_lock() -> None:
    try:
        os.remove(LOCK_FILE)
    except FileNotFoundError:
        pass


def suspend_services() -> None:
    for svc in SUSPEND_SERVICES:
        path = f"/etc/init.d/{svc}"
        if os.path.exists(path):
            subprocess.call([path, "stop"],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def resume_services() -> None:
    for svc in reversed(SUSPEND_SERVICES):
        path = f"/etc/init.d/{svc}"
        if os.path.exists(path):
            subprocess.call([path, "start"],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def build_launch_cmd(manifest: dict, game_dir: str, auto_bootstrap: bool = True) -> list:
    runtime = manifest["runtime"]
    entry = os.path.join(game_dir, manifest["entry"])
    if not os.path.isfile(entry):
        raise FileNotFoundError(f"game entry file not found: {manifest['entry']}")

    # Check if game has a venv directory
    venv_python = os.path.join(game_dir, "venv", "bin", "python3")
    if os.path.isfile(venv_python):
        py = venv_python
    elif runtime in ("okama-lite", "okama-python", "okama-sdl2"):
        py = _python_executable()
    else:
        raise ValueError(f"Unknown runtime: {runtime}")

    if not os.path.isfile(py):
        raise FileNotFoundError(f"python executable not found: {py}")
    if not os.access(py, os.X_OK):
        raise PermissionError(f"python executable is not runnable: {py}")
    if auto_bootstrap:
        return [py, "-c", BOOTSTRAP_STUB, entry]
    return [py, entry]


def _tail_text(path: str, max_bytes: int = 16000) -> str:
    try:
        size = os.path.getsize(path)
        with open(path, "rb") as f:
            if size > max_bytes:
                f.seek(size - max_bytes)
            return f.read().decode(errors="replace")
    except OSError:
        return ""


def _diagnostic_hints(reason: str, output: str) -> list:
    text = f"{reason}\n{output}".lower()
    hints = []
    if "no module named pygame" in text or "importerror: no module named" in text:
        hints.append("Package missing dependency: add python_deps or bundle site-packages.")
    if "no usable sdl display" in text or "display.set_mode" in text or "video system not initialized" in text:
        hints.append("Display failed: use okamaos.display.open_display or rely on v2.1.2 auto framebuffer bootstrap.")
    if "manifest" in text:
        hints.append("Check manifest.ok.json runtime, entry path, ID, permissions, and package format.")
    if "permission denied" in text:
        hints.append("Check executable/read permissions inside the .ok package.")
    if "startup timeout" in text:
        hints.append("Game opened no display frames; verify the main loop reaches display.flip().")
    if "emergency exit" in text:
        hints.append("Emergency exit used; inspect the game loop for blocking work.")
    if "traceback" in text or "runtimeerror" in text or "exception" in text:
        hints.append("The game raised an exception; fix the traceback shown in the crash log.")
    if not hints:
        hints.append("Open the crash log for the Python traceback and last game output.")
    return hints[:4]


def save_crash_log(game_id: str, returncode: int, stderr_out: str,
                   log_path: str = "", reason: str = "") -> str:
    os.makedirs(LOG_DIR, exist_ok=True)
    ts = int(time.time())
    path = os.path.join(LOG_DIR, f"crash_{game_id}_{ts}.log")
    with open(path, "w") as f:
        f.write(f"game_id    : {game_id}\n")
        f.write(f"returncode : {returncode}\n")
        f.write(f"timestamp  : {ts}\n\n")
        if reason:
            f.write(f"reason     : {reason}\n\n")
        if log_path:
            f.write(f"stdout_log : {log_path}\n\n")
            tail = _tail_text(log_path)
            if tail:
                f.write("---- game output tail ----\n")
                f.write(tail)
                f.write("\n")
        if stderr_out:
            f.write("---- launcher details ----\n")
        f.write(stderr_out or "")
    return path


def write_status(status: dict) -> None:
    try:
        os.makedirs(os.path.dirname(STATUS_FILE), exist_ok=True)
        tmp = f"{STATUS_FILE}.tmp"
        with open(tmp, "w") as f:
            json.dump(status, f, indent=2, sort_keys=True)
        os.replace(tmp, STATUS_FILE)
    except OSError:
        pass


def _reader_thread(pipe, log_path: str, out_q: queue.Queue) -> None:
    try:
        with open(log_path, "ab", buffering=0) as log_f:
            while True:
                chunk = pipe.readline()
                if not chunk:
                    break
                log_f.write(chunk)
                out_q.put(chunk.decode(errors="replace"))
    except Exception as e:
        out_q.put(f"[okama-run reader error: {e}]\n")


def _terminate_process(proc: subprocess.Popen, reason: str, grace_sec: float) -> tuple[int, str]:
    if proc.poll() is not None:
        return proc.returncode, reason
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except Exception:
        try:
            proc.terminate()
        except Exception:
            pass
    try:
        return proc.wait(timeout=max(0.1, grace_sec)), reason
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except Exception:
            try:
                proc.kill()
            except Exception:
                pass
        try:
            proc.wait(timeout=1.0)
        except Exception:
            pass
        return proc.returncode if proc.returncode is not None else -9, f"{reason}; forced kill"


def _heartbeat_seen(path: str) -> bool:
    try:
        return os.path.getmtime(path) > 0
    except OSError:
        return False


def _emergency_requested(inp: InputClient, held: set, hold_started: dict, hold_sec: float) -> bool:
    now = time.monotonic()
    for ev in inp.poll():
        if ev.get("type") != "button":
            continue
        btn = ev.get("button")
        if ev.get("state") == "pressed":
            held.add(btn)
        else:
            held.discard(btn)
            hold_started.clear()
    combo = "HOME" in held or ("START" in held and "SELECT" in held)
    if not combo:
        hold_started.pop("emergency", None)
        return False
    hold_started.setdefault("emergency", now)
    return now - hold_started["emergency"] >= hold_sec


def _show_recovery_screen(game_name: str, reason: str, crash_log: str,
                          hints: list, seconds: float = 8.0) -> None:
    try:
        import pygame
        from okamaos.display import open_display
    except Exception:
        return
    try:
        pygame.init()
        screen, display = open_display(
            pygame, 1280, 720, pygame.FULLSCREEN | pygame.NOFRAME,
            caption="OkamaOS Game Recovery")
        font_lg = pygame.font.SysFont("DejaVu Sans", 52, bold=True)
        font_md = pygame.font.SysFont("DejaVu Sans", 28)
        font_sm = pygame.font.SysFont("DejaVu Sans", 22)
        clock = pygame.time.Clock()
        deadline = time.monotonic() + seconds
        while time.monotonic() < deadline:
            for ev in pygame.event.get():
                if ev.type == pygame.QUIT:
                    deadline = 0
                elif ev.type == pygame.KEYDOWN and ev.key in (
                    pygame.K_RETURN, pygame.K_SPACE, pygame.K_ESCAPE):
                    deadline = 0
            screen.fill((8, 10, 22))
            title = font_lg.render("Game did not start safely", True, (255, 80, 110))
            screen.blit(title, (56, 72))
            game_s = font_md.render(game_name, True, (235, 240, 250))
            screen.blit(game_s, (60, 148))
            reason_s = font_sm.render(reason[:105], True, (255, 190, 70))
            screen.blit(reason_s, (60, 198))
            y = 260
            for hint in hints[:4]:
                s = font_sm.render(f"- {hint}"[:115], True, (180, 200, 225))
                screen.blit(s, (76, y))
                y += 34
            log_s = font_sm.render(f"Crash log: {crash_log}"[:118], True, (120, 150, 190))
            screen.blit(log_s, (60, 540))
            foot = font_sm.render("Returning to OkamaOS shell...", True, (120, 150, 190))
            screen.blit(foot, (60, 588))
            display.flip(screen)
            clock.tick(30)
        display.close()
        pygame.quit()
    except Exception:
        try:
            pygame.quit()
        except Exception:
            pass


def main():
    global _ACTIVE_PROC, _SERVICES_SUSPENDED
    p = argparse.ArgumentParser(prog="okama-run")
    p.add_argument("game_id")
    p.add_argument("--no-suspend", action="store_true")
    args = p.parse_args()

    conf = cfg_mod.get()
    dev = conf.is_dev_mode()

    game_id = args.game_id
    game_dir = games_mod.game_dir(game_id)
    manifest_path = os.path.join(game_dir, "manifest.ok.json")

    if not os.path.isdir(game_dir):
        print(f"Game not installed: {game_id}", file=sys.stderr)
        sys.exit(1)

    try:
        manifest = manifest_mod.load_and_validate(manifest_path, dev_mode=dev)
    except manifest_mod.ManifestError as e:
        print(f"Manifest error: {e}", file=sys.stderr)
        sys.exit(1)

    acquire_lock(game_id)
    signal.signal(signal.SIGTERM, _launcher_signal)
    signal.signal(signal.SIGINT, _launcher_signal)

    if not args.no_suspend:
        suspend_services()
        _SERVICES_SUSPENDED = True

    env = os.environ.copy()
    env["OKAMA_GAME_ID"] = game_id
    env["OKAMA_GAME_DIR"] = game_dir
    env.setdefault("OKAMA_SAVES", SAVES_DIR)

    assets_json = os.path.join(SAVES_DIR, "..", "wallet", "assets.json")
    env["OKAMA_ASSETS_PATH"] = os.path.normpath(assets_json)
    try:
        import okamaos.wallet as _w
        env["OKAMA_WALLET_ADDRESS"] = _w.address()
    except Exception:
        pass

    # Self-contained package support: prepend bundled deps so games run
    # without any system-wide pip installs.
    python_path_parts = [OKAMA_LIB_PATH]
    bundled_sp = os.path.join(game_dir, "site-packages")
    if os.path.isdir(bundled_sp):
        python_path_parts.insert(0, bundled_sp)
    python_path_parts.extend(_path_list(env.get("PYTHONPATH", "")))
    env["PYTHONPATH"] = os.pathsep.join(_dedupe_paths(python_path_parts))

    bundled_lib = os.path.join(game_dir, "lib")
    ld_paths = _pygame_lib_dirs() + _path_list(env.get("LD_LIBRARY_PATH", ""))
    if os.path.isdir(bundled_lib):
        ld_paths.insert(0, bundled_lib)
    if ld_paths:
        env["LD_LIBRARY_PATH"] = os.pathsep.join(_dedupe_paths(ld_paths))
    # SDL2's bundled pygame wheel often lacks kmsdrm. Prefer host windows when
    # available, otherwise use offscreen and let okamaos.display copy frames to
    # the framebuffer.
    fb_dev = conf.get("FRAMEBUFFER_DEVICE", "/dev/fb0")
    env["OKAMA_FRAMEBUFFER_DEVICE"] = fb_dev
    if env.get("OKAMA_SDL_VIDEODRIVER"):
        env["SDL_VIDEODRIVER"] = env["OKAMA_SDL_VIDEODRIVER"]
    elif env.get("SDL_VIDEODRIVER"):
        pass
    elif env.get("DISPLAY"):
        env["SDL_VIDEODRIVER"] = "x11"
    elif env.get("WAYLAND_DISPLAY"):
        env["SDL_VIDEODRIVER"] = "wayland"
    elif os.path.exists(fb_dev):
        env["SDL_VIDEODRIVER"] = "offscreen"
        env["SDL_FBDEV"] = fb_dev
    elif os.path.exists("/dev/dri/card0") or os.path.exists("/dev/dri/card1"):
        env["SDL_VIDEODRIVER"] = "kmsdrm"
    env["SDL_AUDIODRIVER"] = "alsa"

    # Performance hardening for games
    # Lock to single CPU to reduce scheduler jitter, enable performance governor
    env["SDL_RENDER_DRIVER"] = "software"
    env["SDL_HIGHDPI_DISABLED"] = "1"
    env["SDL_VIDEO_X11_NODIRECTCOLOR"] = "1"
    env["PYTHONDONTWRITEBYTECODE"] = "1"
    # Reduce input latency hints
    env["SDL_MOUSE_FOCUS_CLICKTHROUGH"] = "1"

    auto_bootstrap = _conf_value(conf, "GAME_AUTO_FB_PRESENT", "yes").lower() == "yes"
    try:
        cmd = build_launch_cmd(manifest, game_dir, auto_bootstrap=auto_bootstrap)
    except ValueError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        if not args.no_suspend:
            resume_services()
        release_lock()
        sys.exit(1)
    except Exception as e:
        print(f"ERROR: {e}", file=sys.stderr)
        if not args.no_suspend:
            resume_services()
        release_lock()
        sys.exit(1)

    print(f"Launching: {manifest['name']} ({game_id})")
    log_path = os.path.join(LOG_DIR, f"{game_id}.log")
    os.makedirs(LOG_DIR, exist_ok=True)

    # Set CPU governor to performance if available
    try:
        with open("/sys/devices/system/cpu/cpu0/cpufreq/scaling_governor", "w") as f:
            f.write("performance\n")
    except Exception:
        pass

    try:
        os.remove(HEARTBEAT_FILE)
    except OSError:
        pass
    env["OKAMA_GAME_HEARTBEAT"] = HEARTBEAT_FILE

    proc = None
    exit_code = 0
    launcher_details = ""
    reason = ""
    output_q: queue.Queue = queue.Queue()
    start_timeout = _conf_float(conf, "GAME_START_TIMEOUT_SEC", 20.0)
    term_grace = _conf_float(conf, "GAME_TERM_GRACE_SEC", 2.0)
    emergency_hold_sec = 2.0
    input_client = InputClient()
    input_client.connect()
    held_buttons = set()
    hold_started = {}
    try:
        with open(log_path, "w") as log_f:
            log_f.write(f"Launching {manifest['name']} ({game_id})\n")
            log_f.write(f"Command: {' '.join(cmd)}\n\n")
        proc = subprocess.Popen(
            cmd,
            cwd=game_dir,
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
        _ACTIVE_PROC = proc
        update_lock_pid(game_id, proc.pid)
        reader = threading.Thread(
            target=_reader_thread,
            args=(proc.stdout, log_path, output_q),
            daemon=True,
        )
        reader.start()
        started_at = time.monotonic()
        first_frame = False
        while True:
            exit_code = proc.poll()
            if exit_code is not None:
                reason = "exited"
                break
            if _heartbeat_seen(HEARTBEAT_FILE):
                first_frame = True
            if not first_frame and time.monotonic() - started_at > start_timeout:
                exit_code, reason = _terminate_process(
                    proc, f"startup timeout after {int(start_timeout)}s", term_grace)
                break
            if _emergency_requested(input_client, held_buttons, hold_started, emergency_hold_sec):
                exit_code, reason = _terminate_process(
                    proc, "emergency exit requested", term_grace)
                break
            time.sleep(0.1)
        try:
            reader.join(timeout=1.0)
        except Exception:
            pass
    except Exception:
        launcher_details = traceback.format_exc()
        exit_code = -1
        reason = "launcher error"
        if proc is not None:
            _terminate_process(proc, reason, term_grace)

    if not args.no_suspend:
        resume_services()
        _SERVICES_SUSPENDED = False

    release_lock()
    _ACTIVE_PROC = None
    try:
        input_client.close()
    except Exception:
        pass

    if exit_code != 0:
        if reason == "exited":
            reason = f"game exited with code {exit_code}"
        output_tail = _tail_text(log_path)
        crash_log = save_crash_log(
            game_id, exit_code, launcher_details,
            log_path=log_path, reason=reason)
        hints = _diagnostic_hints(reason, output_tail + launcher_details)
        write_status({
            "game_id": game_id,
            "name": manifest.get("name", game_id),
            "status": "crashed",
            "reason": reason,
            "returncode": exit_code,
            "log_path": log_path,
            "crash_log": crash_log,
            "hints": hints,
            "timestamp": int(time.time()),
        })
        print(f"Game exited with code {exit_code}. Crash log: {crash_log}")
        for hint in hints:
            print(f"Hint: {hint}")
        print("Returning to OkamaOS shell…")
        if os.environ.get("OKAMA_RECOVERY_SCREEN", "yes").lower() != "no":
            _show_recovery_screen(manifest.get("name", game_id), reason, crash_log, hints)
        sys.exit(1)
    else:
        write_status({
            "game_id": game_id,
            "name": manifest.get("name", game_id),
            "status": "clean",
            "returncode": 0,
            "log_path": log_path,
            "timestamp": int(time.time()),
        })
        print(f"Game finished cleanly. Returning to OkamaOS shell…")
        _submit_game_rewards(game_id)
        sys.exit(0)


def _submit_game_rewards(game_id: str) -> None:
    """Submit any pending play-to-earn reward claims after game exit."""
    try:
        import okamaos.rewards as rewards_mod
        results = rewards_mod.process_game_rewards(
            game_id, SAVES_DIR,
            passphrase_cb=None,
        )
        if results:
            print(f"Reward: submitted {len(results)} claim(s) for {game_id}.")
    except Exception:
        pass


if __name__ == "__main__":
    main()
